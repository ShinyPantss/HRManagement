<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — HepiyiHR</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <span class="brand-mark">HR</span>
                <span class="brand-text">HepiyiHR</span>
            </div>

            @*
                Menü, auth bağlandığında role göre filtrelenecek. Örnek:
                @if (User.IsInRole("Admin") || User.IsInRole("HR")) { ... }
                Henüz controller'ı olmayan öğeler "disabled"; controller geldikçe
                href="#" yerine asp-controller/asp-action yazıp disabled'ı kaldırın.
            *@
            <nav class="sidebar-nav">
                <a class="nav-item @Active("Home")" asp-controller="Home" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/></svg>
                    Ana Sayfa
                </a>
                @* Profilim: kişinin kendi çalışan kaydı. Admin'in çalışan kaydı yok
                   (sistem rolü), Intern'in profili ise Employee değil — ikisine de çıkmaz. *@
                @if (User.Identity?.IsAuthenticated == true
                    && !User.IsInRole("Admin") && !User.IsInRole("Intern"))
                {
                    <a class="nav-item @Active2("Employees", "Profile")" asp-controller="Employees" asp-action="Profile">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>
                        Profilim
                    </a>
                }
                @* "Çalışanlar" adı yalnızca HR/Admin'de: Manager ve Employee aynı
                   ekranı "Ekibim" olarak görür (API içeriği zaten role göre daraltıyor).
                   İleride buradan bir Şirket Organizasyonu sayfası doğacak. *@
                @{
                    var employeesLabel = (User.IsInRole("HR") || User.IsInRole("Admin")) ? "Çalışanlar" : "Ekibim";
                }
                <a class="nav-item @ActiveExcept("Employees", "Profile")" asp-controller="Employees" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    @employeesLabel
                </a>
                @* Mentorluk: Manager da Employee da mentor olabilir — kişi yalnızca
                   KENDİ stajyerlerini görür (yetki API'de, ilişkiden). *@
                @if (User.IsInRole("Manager") || User.IsInRole("Employee"))
                {
                    <a class="nav-item @Active("Mentorship")" asp-controller="Mentorship" asp-action="Index">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10 12 5 2 10l10 5z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/><path d="M22 10v6"/></svg>
                        Mentorluk
                    </a>
                }
                <a class="nav-item @ActiveExcept("LeaveRequests", "Approvals")" asp-controller="LeaveRequests" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    İzin Geçmişi
                </a>
                @* Onay Bekleyenler: yalnızca onaylayabilen roller. *@
                @if (User.IsInRole("HR") || User.IsInRole("Manager") || User.IsInRole("Admin"))
                {
                    <a class="nav-item @Active2("LeaveRequests", "Approvals")" asp-controller="LeaveRequests" asp-action="Approvals">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        Onay Bekleyenler
                    </a>
                }
                @* Stajyerler (tüm liste) yönetim ekranıdır: yalnızca HR/Admin (+Intern
                   kendi dünyası). Manager ve Employee stajyerlere Mentorluk'tan ulaşır. *@
                @if (User.IsInRole("HR") || User.IsInRole("Admin") || User.IsInRole("Intern"))
                {
                    <a class="nav-item @Active("Interns")" asp-controller="Interns" asp-action="Index">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10 12 5 2 10l10 5z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/></svg>
                        Stajyerler
                    </a>
                }
                @* Departmanlar Employee'ye görünmez (kullanıcı kararı). *@
                @if (!User.IsInRole("Employee"))
                {
                    <a class="nav-item @Active("Departments")" asp-controller="Departments" asp-action="Index">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 9h1M9 13h1M14 9h1M14 13h1M11 21v-4h2v4"/></svg>
                        Departmanlar
                    </a>
                }
                @* HR'ın manuel "Hesap Talebi Oluştur" menüsü kaldırıldı: talepler
                   çalışan/stajyer eklenirken otomatik açılıyor. *@

                @* Yalnızca Admin bekleyen talepleri işler. *@
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-item @Active2("AccountRequests", "Pending")" asp-controller="AccountRequests" asp-action="Pending">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        Bekleyen Talepler
                    </a>
                }
            </nav>

            @* İzin talebi kısayolu — sidebar'ın en altı. Talep açabilecek herkes
               görür; yalnızca Admin görmez (çalışan kaydı yok). *@
            @if (User.IsInRole("HR") || User.IsInRole("Manager")
                || User.IsInRole("Employee") || User.IsInRole("Intern"))
            {
                <div class="sidebar-cta">
                    <a asp-controller="LeaveRequests" asp-action="Create" class="sidebar-cta-btn">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4"/></svg>
                        İzin Talep Et
                    </a>
                </div>
            }
        </aside>

        <div class="main">
            <header class="topbar">
                <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Menü">☰</button>
                <div class="topbar-title">@ViewData["Title"]</div>

                @* Bilgiler cookie ticket'ındaki claim'lerden gelir (AccountController.SignInWithTokenAsync). *@
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var userName = User.Identity.Name ?? "";
                    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

                    <div class="user-chip">
                        <span class="user-avatar">@(userName.Length > 0 ? char.ToUpperInvariant(userName[0]).ToString() : "?")</span>
                        <span>@userName <span class="text-muted">· @userRole</span></span>
                        @* Çıkış POST'tur: GET ile olsaydı bir <img src="/Account/Logout"> herkesi atardı (CSRF). *@
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                            <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-2">Çıkış</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="user-chip">
                        <span class="user-avatar">?</span>
                        <a asp-controller="Account" asp-action="Login">Giriş yap</a>
                    </div>
                }
            </header>

            @* Bildirimler toast olarak sağ üstte belirir, otomatik kapanır (Bootstrap). *@
            <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
                @if (TempData["Error"] is string errorMessage)
                {
                    <div class="toast align-items-center text-bg-danger border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">@errorMessage</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
                        </div>
                    </div>
                }
                @if (TempData["Success"] is string successMessage)
                {
                    <div class="toast align-items-center text-bg-success border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">@successMessage</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
                        </div>
                    </div>
                }
            </div>

            <main class="content">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    // Aktif menü öğesi: geçerli controller adı eşleşiyorsa "active" döner.
    string Active(string controller)
    {
        var current = ViewContext.RouteData.Values["controller"] as string ?? "";
        return current.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    // Controller eşleşince aktif, verilen action'lar HARİÇ. Örn. Profilim de
    // Employees controller'ında yaşadığı için "Çalışanlar" menüsü Profile
    // action'ında yanmamalı — o sayfanın menüdeki sahibi Profilim'dir.
    string ActiveExcept(string controller, params string[] excludedActions)
    {
        var c = ViewContext.RouteData.Values["controller"] as string ?? "";
        var a = ViewContext.RouteData.Values["action"] as string ?? "";
        return c.Equals(controller, StringComparison.OrdinalIgnoreCase)
            && !excludedActions.Any(x => x.Equals(a, StringComparison.OrdinalIgnoreCase))
            ? "active" : "";
    }

    // Aynı controller altında iki menü öğesi olduğunda (ör. AccountRequests →
    // Create ve Pending) action'a göre ayırt eder.
    string Active2(string controller, string action)
    {
        var c = ViewContext.RouteData.Values["controller"] as string ?? "";
        var a = ViewContext.RouteData.Values["action"] as string ?? "";
        return c.Equals(controller, StringComparison.OrdinalIgnoreCase)
            && a.Equals(action, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}

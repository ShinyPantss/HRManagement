<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — HepiyiHR</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <span class="brand-mark">HR</span>
                <span class="brand-text">HepiyiHR</span>
            </div>

            @*
                Menü, auth bağlandığında role göre filtrelenecek. Örnek:
                @if (User.IsInRole("Admin") || User.IsInRole("HR")) { ... }
                Henüz controller'ı olmayan öğeler "disabled"; controller geldikçe
                href="#" yerine asp-controller/asp-action yazıp disabled'ı kaldırın.
            *@
            <nav class="sidebar-nav">
                <a class="nav-item @Active("Home")" asp-controller="Home" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/></svg>
                    Ana Sayfa
                </a>
                <a class="nav-item @Active("Employees")" asp-controller="Employees" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Çalışanlar
                </a>
                <a class="nav-item @Active("LeaveRequests")" asp-controller="LeaveRequests" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    İzin Talepleri
                </a>
                <a class="nav-item @Active("Interns")" asp-controller="Interns" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10 12 5 2 10l10 5z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/></svg>
                    Stajyerler
                </a>
                <a class="nav-item @Active("Departments")" asp-controller="Departments" asp-action="Index">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 9h1M9 13h1M14 9h1M14 13h1M11 21v-4h2v4"/></svg>
                    Departmanlar
                </a>
                <a class="nav-item disabled" href="#">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a7 7 0 0 1 10.6-6"/><circle cx="18" cy="18" r="3"/><path d="M18 15v-1M18 22v-1M21 18h-1M16 18h-1"/></svg>
                    Kullanıcılar
                    <span class="nav-badge">yakında</span>
                </a>
            </nav>

            <div class="sidebar-footer">HepiyiHR · staj projesi · v0.1</div>
        </aside>

        <div class="main">
            <header class="topbar">
                <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Menü">☰</button>
                <div class="topbar-title">@ViewData["Title"]</div>

                @* Bilgiler cookie ticket'ındaki claim'lerden gelir (AccountController.SignInWithTokenAsync). *@
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var userName = User.Identity.Name ?? "";
                    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

                    <div class="user-chip">
                        <span class="user-avatar">@(userName.Length > 0 ? char.ToUpperInvariant(userName[0]).ToString() : "?")</span>
                        <span>@userName <span class="text-muted">· @userRole</span></span>
                        @* Çıkış POST'tur: GET ile olsaydı bir <img src="/Account/Logout"> herkesi atardı (CSRF). *@
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                            <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-2">Çıkış</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="user-chip">
                        <span class="user-avatar">?</span>
                        <a asp-controller="Account" asp-action="Login">Giriş yap</a>
                    </div>
                }
            </header>

            <main class="content">
                @if (TempData["Error"] is string errorMessage)
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
                @if (TempData["Success"] is string successMessage)
                {
                    <div class="alert alert-success">@successMessage</div>
                }
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    // Aktif menü öğesi: geçerli controller adı eşleşiyorsa "active" döner.
    string Active(string controller)
    {
        var current = ViewContext.RouteData.Values["controller"] as string ?? "";
        return current.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}

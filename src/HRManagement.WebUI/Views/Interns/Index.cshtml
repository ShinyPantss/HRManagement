@model IEnumerable<HRManagement.WebUI.Models.Api.Interns.InternResponse>
@{
    ViewData["Title"] = "Stajyerler";
    var canCreate = User.IsInRole("HR");      // yeni kayıt açmak yalnızca İK
    var canManage = User.IsInRole("HR") || User.IsInRole("Admin");   // düzenleme
    var canDelete = User.IsInRole("Admin");   // silme yalnızca Admin
}

<div class="page-head d-flex align-items-center">
    <div>
        <h1>Stajyerler</h1>
        <p class="text-muted mb-0">Şirketteki tüm stajyerler.</p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-primary ms-auto">Yeni Stajyer</a>
    }
</div>

<div class="panel mt-3">
    <div class="panel-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>Üniversite</th>
                    <th>Bölüm</th>
                    <th>Sınıf</th>
                    <th>Staj Tarihleri</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var intern in Model)
                {
                    <tr>
                        <td>@intern.Id</td>
                        <td>@intern.FirstName</td>
                        <td>@intern.LastName</td>
                        <td>@intern.University</td>
                        <td>@(string.IsNullOrWhiteSpace(intern.Major) ? "—" : intern.Major)</td>
                        <td>@intern.Grade</td>
                        <td>@intern.StartDate.ToString("dd.MM.yyyy") – @intern.EndDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-end">
                            @if (canManage)
                            {
                                <a asp-action="Edit" asp-route-id="@intern.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            }
                            @if (canDelete)
                            {
                                <form asp-action="Delete" asp-route-id="@intern.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu stajyeri silmek istediğinize emin misiniz? Hesabı pasife alınır, izin/hesap talepleri silinir.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Henüz stajyer kaydı yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

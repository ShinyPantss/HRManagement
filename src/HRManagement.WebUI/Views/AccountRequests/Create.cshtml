@model HRManagement.WebUI.Models.AccountRequests.CreateAccountRequestViewModel
@{
    ViewData["Title"] = "Hesap Talebi Oluştur";
}

<div class="page-head">
    <h1>Hesap Talebi Oluştur</h1>
    <p class="text-muted mb-0">Hesabı olmayan bir çalışan/stajyer için talep açın. Onayı Admin verir.</p>
</div>

<div class="panel mt-3" style="max-width: 640px;">
    <div class="panel-body">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label"></label>
                <select asp-for="Subject" asp-items="Model.SubjectOptions" class="form-select">
                    <option value="">Kişi seçiniz…</option>
                </select>
                <span asp-validation-for="Subject" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SuggestedRole" class="form-label"></label>
                <select asp-for="SuggestedRole" asp-items="Model.RoleOptions" class="form-select"></select>
                <span asp-validation-for="SuggestedRole" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Note" class="form-label"></label>
                <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Note" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Talep Oluştur</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

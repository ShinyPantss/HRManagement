@model HRManagement.WebUI.Models.AccountRequests.ApproveAccountRequestViewModel
@{
    ViewData["Title"] = "Talebi Onayla";
}

<div class="page-head">
    <h1>Talebi Onayla — Hesap Aç</h1>
    <p class="text-muted mb-0">@Model.SubjectType: <strong>@Model.SubjectName</strong> · Otomatik rol: @Model.SuggestedRole</p>
</div>

<div class="panel mt-3" style="max-width: 640px;">
    <div class="panel-body">
        <form asp-action="Approve" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SubjectName" />
            <input type="hidden" asp-for="SubjectType" />
            <input type="hidden" asp-for="SuggestedRole" />

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="off" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="off" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="text" class="form-control" autocomplete="off" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div class="form-text">Otomatik üretilir; kullanıcıya iletin, ilk girişte değiştirmeli.</div>
            </div>

            @* Rol SEÇİLMEZ: talebin (kişiden türetilmiş) rolü kullanılır — üstte
               "Otomatik rol" olarak görünüyor. *@
            <div class="alert alert-light border small text-muted py-2">
                Rol otomatik atanır: <strong>@Model.SuggestedRole</strong>. Onaylarken yalnızca
                kullanıcı adı, e-posta ve geçici şifre belirlenir.
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Onayla ve Hesabı Aç</button>
                <a asp-action="Pending" class="btn btn-outline-secondary">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

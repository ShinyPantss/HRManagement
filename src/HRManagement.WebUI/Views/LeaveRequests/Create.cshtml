@model HRManagement.WebUI.Models.LeaveRequests.LeaveRequestFormViewModel
@{
    ViewData["Title"] = "Yeni İzin Talebi";
}

<div class="page-head">
    <h1>Yeni İzin Talebi</h1>
    <p class="text-muted mb-0">Talep, giriş yaptığınız hesap adına oluşturulur. İzin türü ve tarih aralığı zorunludur.</p>
</div>

<div class="panel mt-3" style="max-width: 640px;">
    <div class="panel-body">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Type" class="form-label"></label>
                <select asp-for="Type" asp-items="Model.TypeOptions" class="form-select"></select>
                <span asp-validation-for="Type" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-sm-6 mb-3">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="text" class="form-control" placeholder="gg.aa.yyyy" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-sm-6 mb-3">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="text" class="form-control" placeholder="gg.aa.yyyy" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            @* Rapor alanı: yalnızca Hastalık İzni (Type == 3) seçildiğinde görünür.
               Sunucu tarafı da bu kuralı doğrular; JS yalnızca UX içindir. *@
            <div class="mb-3" id="medicalReportGroup">
                <label asp-for="MedicalReport" class="form-label"></label>
                <textarea asp-for="MedicalReport" class="form-control" rows="2"
                          placeholder="Rapor no / doktor / kurum bilgisi"></textarea>
                <span asp-validation-for="MedicalReport" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Rapor alanını izin türüne göre göster/gizle: 3 = Hastalık İzni.
        (function () {
            var typeSelect = document.getElementById('@Html.IdFor(m => m.Type)');
            var reportGroup = document.getElementById('medicalReportGroup');
            if (!typeSelect || !reportGroup) return;

            function toggle() {
                reportGroup.style.display = typeSelect.value === '3' ? '' : 'none';
            }
            typeSelect.addEventListener('change', toggle);
            toggle(); // ilk yüklemede mevcut seçime göre ayarla
        })();
    </script>
}

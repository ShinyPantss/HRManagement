@model HRManagement.WebUI.Models.LeaveRequests.LeaveRequestListViewModel
@{
    ViewData["Title"] = "İzin Talepleri";
}

<div class="page-head d-flex align-items-center">
    <div>
        <h1>İzin Talepleri</h1>
        <p class="text-muted mb-0">
            @(Model.ShowEmployeePicker
                ? "Talepler çalışan bazında listelenir; önce bir çalışan seçin."
                : "Kendi izin talepleriniz.")
        </p>
    </div>
    <a asp-action="Create" class="btn btn-primary ms-auto">Yeni İzin Talebi</a>
</div>

@* Çalışan seçici yalnızca HR/Admin'e: seçim query string'e (?employeeId=..) yazılır,
   böylece liste paylaşılabilir/yenilenebilir bir URL'e sahip olur. Diğer roller
   kendi izinlerine sabitlenir (controller), seçici gösterilmez. *@
@if (Model.ShowEmployeePicker)
{
    <div class="panel mt-3">
        <div class="panel-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-sm-6 col-md-4">
                    <label class="form-label" for="employeeId">Çalışan</label>
                    <select name="employeeId" id="employeeId" class="form-select">
                        <option value="">Çalışan seçiniz</option>
                        @foreach (var option in Model.EmployeeOptions)
                        {
                            <option value="@option.Value" selected="@(option.Value == Model.SelectedEmployeeId?.ToString())">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-sm-auto">
                    <button type="submit" class="btn btn-outline-secondary">Göster</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="panel mt-3">
    <div class="panel-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Tür</th>
                    <th>Başlangıç</th>
                    <th>Bitiş</th>
                    <th>Gün</th>
                    <th>Durum</th>
                    <th>Açıklama</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model.Requests)
                {
                    // Durum rozetinin rengi ve Türkçe karşılığı.
                    var (badgeClass, statusText) = request.Status switch
                    {
                        "Pending" => ("text-bg-warning", "Beklemede"),
                        "Approved" => ("text-bg-success", "Onaylandı"),
                        "Rejected" => ("text-bg-danger", "Reddedildi"),
                        _ => ("text-bg-secondary", request.Status)
                    };

                    <tr>
                        <td>@request.Id</td>
                        <td>@request.Type</td>
                        <td>@request.StartDate.ToString("dd.MM.yyyy")</td>
                        <td>@request.EndDate.ToString("dd.MM.yyyy")</td>
                        <td>@request.TotalDays</td>
                        <td>
                            <span class="badge @badgeClass" title="@request.RejectionReason">@statusText</span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(request.Description) ? "—" : request.Description)</td>
                        <td class="text-end">
                            @* Buton görünürlüğü kişiye göre: KENDİ talebimde Onayla/Reddet
                               çıkmaz (self-approval yasak); Sil ise YALNIZCA kendi talebimde çıkar. *@
                            @{ var kendiTalebim = request.EmployeeId == Model.CurrentEmployeeId; }
                            @if (request.Status == "Pending" && !kendiTalebim)
                            {
                                <form asp-action="Approve" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu izin talebini onaylamak istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <input type="hidden" name="employeeId" value="@Model.SelectedEmployeeId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Onayla</button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline"
                                      onsubmit="return izinRedGerekcesiSor(this);">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <input type="hidden" name="employeeId" value="@Model.SelectedEmployeeId" />
                                    @* Gerekçe submit anında prompt ile doldurulur. *@
                                    <input type="hidden" name="reason" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Reddet</button>
                                </form>
                            }
                            @if (kendiTalebim)
                            {
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu izin talebini silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <input type="hidden" name="employeeId" value="@Model.SelectedEmployeeId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Requests.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            @(!Model.ShowEmployeePicker
                                ? "İzin talebiniz yok."
                                : Model.SelectedEmployeeId is null
                                    ? "Talepleri görmek için yukarıdan bir çalışan seçin."
                                    : "Seçili çalışana ait izin talebi yok.")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Reddetme gerekçesini formun gizli alanına yazar. Kullanıcı iptal ederse
        // false döner ve form gönderilmez.
        function izinRedGerekcesiSor(form) {
            var reason = prompt('Red gerekçesi (opsiyonel):', '');
            if (reason === null) {
                return false;
            }
            form.elements['reason'].value = reason;
            return true;
        }
    </script>
}

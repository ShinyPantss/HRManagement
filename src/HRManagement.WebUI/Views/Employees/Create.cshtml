@model HRManagement.WebUI.Models.Employees.EmployeeFormViewModel
@{
    ViewData["Title"] = "Yeni Çalışan";
}

<div class="page-head">
    <h1>Yeni Çalışan</h1>
    <p class="text-muted mb-0">Yıldızsız görünen alanlardan T.C. kimlik no ve telefon opsiyoneldir.</p>
</div>

<div class="panel mt-3" style="max-width: 860px;">
    <div class="panel-body">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NationalId" class="form-label"></label>
                    <input asp-for="NationalId" class="form-control" />
                    <span asp-validation-for="NationalId" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Seniority" class="form-label"></label>
                    <select asp-for="Seniority" asp-items="Model.SeniorityOptions" class="form-select">
                        <option value="">Seçiniz…</option>
                    </select>
                    <span asp-validation-for="Seniority" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BirthDate" class="form-label"></label>
                    @* type="date" tarayıcı takvimi açar; value ISO (yyyy-MM-dd) ister,
                       asp-format ViewModel'deki dd.MM.yyyy edit formatını bu input için ezer. *@
                    <input asp-for="BirthDate" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" />
                    <span asp-validation-for="BirthDate" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="HireDate" class="form-label"></label>
                    <input asp-for="HireDate" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" />
                    <span asp-validation-for="HireDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DepartmentId" class="form-label"></label>
                    <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select">
                        <option value="">Seçiniz…</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ManagerId" class="form-label"></label>
                    <select asp-for="ManagerId" class="form-select" data-manager-select>
                        <option value="">Yok (zincirin tepesi)</option>
                        @foreach (var m in Model.ManagerCandidates)
                        {
                            <option value="@m.Id" data-seniority="@m.Seniority" data-department="@m.DepartmentId">@m.Name</option>
                        }
                    </select>
                    <span asp-validation-for="ManagerId" class="text-danger small"></span>
                    <div class="form-text">Yalnızca Müdür, GMY, GM ve çalışandan kıdemli olanlar listelenir.</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3" id="unitGroup">
                    <label asp-for="UnitId" class="form-label"></label>
                    <select asp-for="UnitId" class="form-select" data-unit-select>
                        <option value="">Birim yok / seçiniz…</option>
                        @foreach (var u in Model.UnitCandidates)
                        {
                            <option value="@u.Id" data-department="@u.DepartmentId">@u.Name</option>
                        }
                    </select>
                    <span asp-validation-for="UnitId" class="text-danger small"></span>
                    <div class="form-text">Seçilen departmana göre süzülür; zorunlu değil.</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="UserId" class="form-label"></label>
                    <input asp-for="UserId" type="number" class="form-control" />
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="AnnualLeaveDays" class="form-label"></label>
                    <input asp-for="AnnualLeaveDays" type="number" class="form-control" />
                    <span asp-validation-for="AnnualLeaveDays" class="text-danger small"></span>
                </div>
            </div>

            @* Otomatik hesap talebi: işaretliyse çalışan eklenince Admin'e Pending
               talep düşer (HR ayrıca talep açmaz). Yukarıda mevcut bir hesap Id'si
               yazıldıysa sunucu talebi zaten açmaz. *@
            <div class="form-check mb-3">
                <input asp-for="RequestLoginAccount" class="form-check-input" />
                <label asp-for="RequestLoginAccount" class="form-check-label"></label>
                <div class="form-text">Onayı Admin verir; işaretli değilse hesap talebi oluşmaz.</div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ManagerSeniorityFilter" />
    <partial name="_UnitDepartmentFilter" />
}

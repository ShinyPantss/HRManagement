@model IEnumerable<HRManagement.WebUI.Models.Api.Employees.EmployeeResponse>
@{
    ViewData["Title"] = "Çalışanlar";
}

<div class="page-head d-flex align-items-center">
    <div>
        <h1>Çalışanlar</h1>
        <p class="text-muted mb-0">Şirketteki tüm çalışanlar.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary ms-auto">Yeni Çalışan</a>
</div>

<div class="panel mt-3">
    <div class="panel-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>E-posta</th>
                    <th>Pozisyon</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model)
                {
                    <tr>
                        <td>@employee.Id</td>
                        <td>@employee.FirstName</td>
                        <td>@employee.LastName</td>
                        <td>@employee.Email</td>
                        <td>@employee.Position</td>
                        <td>
                            @if (employee.IsActive)
                            {
                                <span class="badge text-bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Pasif</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            <form asp-action="Delete" asp-route-id="@employee.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu çalışanı silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Henüz çalışan kaydı yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
